{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=docarchive;Username=docarchive;Password=docarchive_pass"
  },
  "Jwt": {
    "Secret": "CHANGE_THIS_TO_A_SECURE_SECRET_KEY_AT_LEAST_32_CHARS_LONG_FOR_PRODUCTION",
    "Issuer": "DocArchive",
    "Audience": "DocArchive",
    "AccessTokenMinutes": "15"
  },
  "Storage": {
    "Path": "/app/storage"
  },
  "Cors": {
    "Origins": ["http://localhost:5173", "http://localhost:80", "http://localhost"]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Forwarded-For",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "post:/api/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 30
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
